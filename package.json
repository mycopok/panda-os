{
  "name": "pandaos",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "PandaOS: an open-source, non-custodial AI agent for the Base network. Agent core, a headless CLI, and a web terminal.",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=18", "pnpm": ">=9" },
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "dev": "pnpm --filter @pandaos/interface dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "cli": "node lib/cli/src/cli.js",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "~5.6.3"
  }
}
