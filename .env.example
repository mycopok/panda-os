# All optional. The agent runs read-only out of the box with no keys.
BASE_RPC=https://mainnet.base.org
# Set a default wallet so "balance"/"holdings" work without typing an address:
WALLET_ADDRESS=
# Optional: enable natural-language input (OpenAI-compatible Chat Completions). Without it,
# the agent uses its built-in command parser.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
